# Claude Grocery - Environment Configuration
# Copy this file to .env and fill in your values.

# =============================================================================
# Kroger API (King Soopers Integration) - Recommended
# =============================================================================
# Register for free at https://developer.kroger.com
# Create an application to get your Client ID and Client Secret.
# Enables: product search with pricing, store finder, budget estimation.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# =============================================================================
# Instacart Developer Platform (Safeway + Multi-Store) - Optional
# =============================================================================
# Apply at https://www.instacart.com/company/business/developers
# Enables: shoppable Instacart lists with direct checkout URL for Safeway,
# Costco, Sprouts, Target, Whole Foods, and 1800+ other retailers.
INSTACART_API_KEY=

# =============================================================================
# Walmart (Deep Links) - Optional
# =============================================================================
# No API key required for basic Walmart link generation.
# Optionally provide an Impact Radius affiliate ID for monetized links.
WALMART_AFFILIATE_ID=

# =============================================================================
# Default ZIP Code - Optional
# =============================================================================
# Your Colorado ZIP code for finding nearby stores.
# Can also be set via the manage_household tool or Desktop Extension config.
ZIP_CODE=
